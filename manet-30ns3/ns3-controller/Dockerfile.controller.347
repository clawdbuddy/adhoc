# NS-3 MANET 控制器 Dockerfile（NS-3.47 源码编译 / linux/amd64）
# 与默认 Dockerfile.controller（NS-3.36 + pybindgen）并存。
# NS-3.37 起 pybindgen 已被移除，3.47 只剩 cppyy 一条 Python 绑定路径。
#
# apt 源：中科大 mirrors.ustc.edu.cn
# pip 源：腾讯 mirrors.cloud.tencent.com

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# --- 0. 替换 apt 源为国科大镜像 ---
RUN sed -i 's/archive.ubuntu.com/mirrors.ustc.edu.cn/g' /etc/apt/sources.list \
    && sed -i 's/security.ubuntu.com/mirrors.ustc.edu.cn/g' /etc/apt/sources.list

# --- 1. 构建依赖（拆 3 段以降低 apt/dpkg 单步内存峰值） ---
# 1a: 编译工具链 + ccache
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential g++ gcc make cmake ninja-build pkg-config \
    git wget curl tar bzip2 xz-utils ccache ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 1b: NS-3 编译依赖（boost / gsl / sqlite / xml / gtk / pcap）
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-all-dev libgsl-dev \
    libsqlite3-dev sqlite3 libxml2-dev libgtk-3-dev libpcap-dev \
    python3 python3-dev python3-pip python3-setuptools python3-wheel \
    && rm -rf /var/lib/apt/lists/*

# 1c: 运行时网络工具（仿真节点诊断 / pcap dump / coreutils 提供 timeout）
RUN apt-get update && apt-get install -y --no-install-recommends \
    vim htop net-tools iputils-ping bridge-utils \
    iproute2 tcpdump iw wireless-tools socat nmap coreutils \
    && rm -rf /var/lib/apt/lists/*

# --- 2. 替换 pip 源为腾讯镜像 ---
RUN pip3 config set global.index-url https://mirrors.cloud.tencent.com/pypi/simple \
    && pip3 config set global.trusted-host mirrors.cloud.tencent.com

# --- 3. Python 运行时依赖 ---
# cppyy: NS-3.47 唯一支持的 Python 绑定后端（pybindgen 已在 3.37 移除）。
# 严格 pin 3.1.2 — 与 ns-3.42–3.47 测过；ABI 在 minor 间不稳，升级 NS-3 时同步对照
# https://www.nsnam.org/docs/manual/html/python.html
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel \
    && python3 -m pip install --no-cache-dir cppyy==3.1.2 \
    && python3 -m pip install --no-cache-dir \
        fastapi==0.110.* "uvicorn[standard]"==0.29.* \
        pydantic==2.* pydantic-settings==2.* \
        docker==7.* pyroute2==0.7.* \
        websockets==12.* httpx==0.27.*

# --- 4. ccache 加速（与 3.36 镜像共用 /ccache 卷时部分对象可复用） ---
ENV PATH="/usr/lib/ccache:$PATH"
ENV CCACHE_DIR=/ccache
RUN mkdir -p /ccache && ccache --max-size=10G

# --- 5. 编译标志（Ubuntu 22.04 GCC 11 支持 x86-64-v2） ---
RUN echo "Building for linux/amd64 with -O3 -march=x86-64-v2" && \
    echo 'CXXFLAGS="-O3 -march=x86-64-v2 -DNDEBUG"' >  /etc/ns3-build-env && \
    echo 'CFLAGS="-O3 -march=x86-64-v2 -DNDEBUG"'  >> /etc/ns3-build-env

# --- 6. 使用本地 NS-3.47 源码包 ---
WORKDIR /opt/ns3
ARG NS3_VERSION=3.47
COPY ns-allinone-${NS3_VERSION}.tar.bz2 /opt/ns3/
RUN tar xjf ns-allinone-${NS3_VERSION}.tar.bz2 \
    && rm ns-allinone-${NS3_VERSION}.tar.bz2 \
    && ln -s ns-allinone-${NS3_VERSION}/ns-${NS3_VERSION} ns-3

# 修复 NS-3.47 + cppyy/Cling 兼容性：模板类里的 dependent type
# 缺少 typename，GCC 能过但 Cling JIT 解析报错。
RUN sed -i \
    -e 's/typedef std::list<IpRoutingTableEntry\*>::iterator/typedef typename std::list<IpRoutingTableEntry*>::iterator/g' \
    -e 's/typedef std::list<IpRoutingTableEntry\*>::const_iterator/typedef typename std::list<IpRoutingTableEntry*>::const_iterator/g' \
    /opt/ns3/ns-3/src/internet/model/global-routing.h \
    /opt/ns3/ns-3/src/internet/model/global-router-interface.h

# --- 7. 配置并编译 NS-3（cmake + cppyy 自动绑定） ---
WORKDIR /opt/ns3/ns-3
ARG NS3_JOBS=16
RUN if [ -f /etc/ns3-build-env ]; then set -a && . /etc/ns3-build-env && set +a; fi && \
    ./ns3 configure \
    --build-profile=optimized \
    --disable-examples --disable-tests \
    --enable-python-bindings \
    --enable-modules="core;network;internet;wifi;mobility;tap-bridge;flow-monitor;propagation;spectrum;aodv;olsr;dsdv;dsr;mesh" \
    && ./ns3 build -j${NS3_JOBS}

# --- 8. 预热 cppyy PCH 缓存 ---
# 第一次 `from ns import ns` 时 Cling 要 JIT-parse 全部 NS-3 头文件（30–60s + 2–4GB RAM）。
# 在镜像层里跑一次，把生成的 .pcm/.pch 烤进 ~/.cache/cppyy/，运行时 import 降到 ~5s。
# 失败不致命：用 `|| true` 容错（确实命中已知 hang 时由 step 9 报错）。
RUN PYTHONPATH="/opt/ns3/ns-3/build/bindings/python:${PYTHONPATH}" \
    timeout 180 python3 -c "from ns import ns; _ = ns.Simulator" || true

# --- 9. 验证（带 180s 超时，防 cppyy 死循环阻塞 build） ---
# cppyy 路线下所有类都挂在扁平 ns3 命名空间下（ns.Simulator / ns.WifiHelper …）。
# sim_runner.py 内部已用 _CppyyNsWrapper 做兼容，现有 ns.core.Simulator 等调用
# 站点无需改动。
RUN PYTHONPATH="/opt/ns3/ns-3/build/bindings/python:${PYTHONPATH}" \
    timeout 180 python3 -c "from ns import ns; \
    _ = ns.Simulator; \
    _ = ns.WifiHelper; \
    _ = ns.TapBridgeHelper; \
    _ = ns.MeshHelper; \
    _ = ns.MultiModelSpectrumChannel; \
    print('ns-3.47 cppyy bindings OK')" \
    || (echo '!!! cppyy 烟雾测试失败:可能命中 cppyy/cling 初始化死循环'; exit 1)

# --- 10. 环境变量 ---
ENV NS3_DIR=/opt/ns3/ns-3
ENV PATH="${NS3_DIR}:${PATH}"
ENV LD_LIBRARY_PATH="${NS3_DIR}/build/lib:${LD_LIBRARY_PATH}"
ENV PYTHONPATH="${NS3_DIR}/build/bindings/python:/app:${PYTHONPATH}"

# --- 11. 控制器代码 + UI 静态资源 ---
WORKDIR /app
COPY controller /app/controller
COPY web-manager/dist /app/dist

ENV MANET_WEB_DIR=/app/dist
EXPOSE 8000

WORKDIR /app
CMD ["uvicorn", "controller.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
