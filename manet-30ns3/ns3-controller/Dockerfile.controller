# NS-3 AdHoc Multi-Arch Dockerfile (x86_64 / ARM64)
# Supports: x86_64 desktop/server, Raspberry Pi, RK3588, Apple Silicon VMs, AWS Graviton, Ampere Altra
# Routing modules: AODV, OLSR, DSDV, DSR

FROM --platform=$TARGETPLATFORM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# --- 1. Build dependencies ---
RUN apt-get update && apt-get install -y \
    build-essential g++ gcc make cmake ninja-build pkg-config \
    python3 python3-dev python3-pip python3-setuptools python3-wheel \
    git wget curl tar bzip2 xz-utils \
    libboost-all-dev libgsl-dev \
    libsqlite3-dev sqlite3 libxml2-dev libgtk-3-dev libpcap-dev \
    ccache vim htop net-tools iputils-ping bridge-utils \
    iproute2 tcpdump iw wireless-tools socat nmap \
    && rm -rf /var/lib/apt/lists/*

# Python deps for ns-3 bindings (cppyy-based) + orchestrator runtime
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel \
    && python3 -m pip install --no-cache-dir \
        cppyy==2.4.* pybind11 \
        fastapi==0.110.* "uvicorn[standard]"==0.29.* \
        pydantic==2.* pydantic-settings==2.* \
        docker==7.* pyroute2==0.7.* \
        websockets==12.* httpx==0.27.*

# --- 2. ccache acceleration ---
ENV PATH="/usr/lib/ccache:$PATH"
ENV CCACHE_DIR=/ccache
RUN mkdir -p /ccache && ccache --max-size=10G

# --- 3. Detect architecture and set compile flags ---
ARG TARGETPLATFORM
ARG BUILDPLATFORM
ARG TARGETARCH
RUN echo "Building for TARGETPLATFORM=$TARGETPLATFORM, BUILDPLATFORM=$BUILDPLATFORM, ARCH=$TARGETARCH"

# Architecture-specific compile optimizations
RUN if [ "$TARGETARCH" = "arm64" ]; then \
        echo "ARM64 detected: using conservative -O3" && \
        export CXXFLAGS="-O3 -DNDEBUG" && \
        export CFLAGS="-O3 -DNDEBUG"; \
    else \
        echo "x86_64 detected: using -O3 -march=x86-64-v2" && \
        export CXXFLAGS="-O3 -march=x86-64-v2 -DNDEBUG" && \
        export CFLAGS="-O3 -march=x86-64-v2 -DNDEBUG"; \
    fi && \
    echo "CXXFLAGS=$CXXFLAGS" >> /etc/ns3-build-env

# --- 4. Fetch NS-3.45 ---
WORKDIR /opt/ns3
ARG NS3_VERSION=3.45
RUN wget -q https://www.nsnam.org/releases/ns-${NS3_VERSION}.tar.bz2 \
    && tar xjf ns-${NS3_VERSION}.tar.bz2 \
    && rm ns-${NS3_VERSION}.tar.bz2 \
    && ln -s ns-${NS3_VERSION} ns-3

# --- 5. Configure & build NS-3 (AdHoc full modules) ---
# Modules: core+network+internet+wifi+mobility+tap-bridge+
#          aodv+olsr+dsdv+dsr+flow-monitor+propagation+spectrum
WORKDIR /opt/ns3/ns-3
RUN if [ -f /etc/ns3-build-env ]; then export $(cat /etc/ns3-build-env | xargs); fi && \
    ./ns3 configure \
    --build-profile=optimized \
    --enable-examples --enable-tests \
    --enable-python-bindings \
    --enable-modules="core;network;internet;wifi;mobility;tap-bridge;flow-monitor;propagation;spectrum;aodv;olsr;dsdv;dsr" \
    && ./ns3 build -j$(nproc)

# --- 6. Verify (C++ + Python bindings) ---
RUN ./ns3 run hello-simulator
RUN PYTHONPATH="/opt/ns3/ns-3/build/bindings/python:${PYTHONPATH}" \
    python3 -c "from ns import ns; _ = ns.core.Simulator; _ = ns.wifi.WifiHelper; _ = ns.tap_bridge.TapBridgeHelper; print('ns-3 python bindings OK')"

# --- 6. Environment ---
ENV NS3_DIR=/opt/ns3/ns-3
ENV PATH="${NS3_DIR}:${PATH}"
ENV LD_LIBRARY_PATH="${NS3_DIR}/build/lib:${LD_LIBRARY_PATH}"
ENV PYTHONPATH="${NS3_DIR}/build/bindings/python:/app:${PYTHONPATH}"

# --- 7. Controller package + UI assets ---
# Build context must be `manet-30ns3/` (project root) so these COPYs resolve.
WORKDIR /app
COPY controller /app/controller
COPY web-manager /app/dist

ENV MANET_WEB_DIR=/app/dist
EXPOSE 8000

WORKDIR /app
CMD ["uvicorn", "controller.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
