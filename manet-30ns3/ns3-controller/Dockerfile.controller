# NS-3 MANET 控制器 Dockerfile（linux/amd64）
# 采用 Ubuntu 22.04 + pip install ns3（预编译 Python 绑定）

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# --- 1. 系统运行时依赖 ---
# ns-3 pip 包包含预编译的 .so，但仍需要系统库（libboost、libpcap、libgsl 等）才能加载。
RUN apt-get update && apt-get install -y \
    python3 python3-pip \
    iproute2 net-tools iputils-ping bridge-utils \
    tcpdump iw wireless-tools socat nmap \
    libboost-all-dev libgsl-dev libpcap-dev \
    libsqlite3-dev sqlite3 libxml2-dev \
    vim htop curl wget \
    && rm -rf /var/lib/apt/lists/*

# --- 2. Python 依赖 ---
# ns-3：通过 pip 安装预编译包（含 mesh / spectrum / tap-bridge / aodv / olsr / dsdv / dsr）
# 控制器运行时：FastAPI + Docker SDK + pyroute2
RUN python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel \
    && python3 -m pip install --no-cache-dir ns3 \
    && python3 -m pip install --no-cache-dir \
        fastapi==0.110.* "uvicorn[standard]"==0.29.* \
        pydantic==2.* pydantic-settings==2.* \
        docker==7.* pyroute2==0.7.* \
        websockets==12.* httpx==0.27.*

# --- 3. 验证 ns-3 Python 绑定 ---
RUN python3 -c "from ns import ns; \
    _ = ns.core.Simulator; \
    _ = ns.wifi.WifiHelper; \
    _ = ns.tap_bridge.TapBridgeHelper; \
    _ = ns.mesh.MeshHelper; \
    _ = ns.spectrum.MultiModelSpectrumChannel; \
    print('ns-3 python bindings OK (版本:', ns.core.NS3_VERSION, ', 含 mesh + spectrum)')"

# --- 4. 控制器代码 + UI 静态资源 ---
# 构建上下文必须是 manet-30ns3/（项目根目录）
WORKDIR /app
COPY controller /app/controller
COPY web-manager /app/dist

ENV MANET_WEB_DIR=/app/dist
EXPOSE 8000

WORKDIR /app
CMD ["uvicorn", "controller.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
